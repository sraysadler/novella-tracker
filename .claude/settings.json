{
  "permissions": {
    "allow": [
      "npm run build",
      "npm run dev",
      "npm run seed",
      "npm install",
      "npm install *",
      "git add",
      "git commit",
      "git push",
      "git pull",
      "git status",
      "git diff",
      "git log",
      "git branch",
      "git checkout",
      "git stash",
      "git worktree",
      "git fetch",
      "find",
      "find *",
      "ls",
      "ls *",
      "cat",
      "cat *",
      "echo",
      "pwd",
      "mkdir",
      "mkdir *",
      "rm",
      "rm *",
      "cp",
      "cp *",
      "mv",
      "mv *",
      "which",
      "which *",
      "/opt/homebrew/bin/npm *",
      "/usr/local/bin/npm *",
      "npx *",
      "tsx *"
    ]
  }
}
